    "Delete": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除"
          }
        }
      }
    },
    "Delete Worktree": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "worktree を削除"
          }
        }
      }
    },
    "Delete Worktree…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "worktree を削除…"
          }
        }
      }
    },
    "Destination Template (can be overridden here)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "作成先テンプレート(その場上書き可)"
          }
        }
      }
    },
    "Destination Template:": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "作成先テンプレート:"
          }
        }
      }
    },
    "Discovery Roots:": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動検出ルート:"
          }
        }
      }
    },
    "Example: feat/x in myapp → %@": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "例: myapp の feat/x → %@"
          }
        }
      }
    },
    "Force Delete": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "強制削除"
          }
        }
      }
    },
    "General": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一般"
          }
        }
      }
    },
    "Git repositories under the discovery roots (up to depth 4, excluding node_modules and the like) are added to the sidebar automatically at launch and on refresh. Registered repositories are always shown in addition to those.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動検出ルート配下の git リポジトリ(深さ4まで、node_modules 等は除外)は起動時・更新時に自動でサイドバーに追加されます。登録リポジトリはそれとは別に常に表示されます。"
          }
        }
      }
    },
    "Has staged changes": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ステージ済みの変更あり"
          }
        }
      }
    },
    "Has unstaged changes": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未ステージの変更あり"
          }
        }
      }
    },
    "Jump to Latest Waiting Session": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最新の入力待ちへ"
          }
        }
      }
    },
    "Launch a session after creation": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "作成後にセッションを起動"
          }
        }
      }
    },
    "Launch a session after creation: %@": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "作成後にセッションを起動: %@"
          }
        }
      }
    },
    "Merge %@ into %@": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ を %2$@ にマージ"
          }
        }
      }
    },
    "Merge into Default Branch…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デフォルトブランチにマージ…"
          }
        }
      }
    },
    "New Session": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新規セッション"
          }
