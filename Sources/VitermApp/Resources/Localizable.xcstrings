{
  "sourceLanguage": "en",
  "strings": {
    "%@ has uncommitted changes. Force delete?": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ には未コミットの変更があります。強制削除しますか?"
          }
        }
      }
    },
    "(current HEAD)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "(現在の HEAD)"
          }
        }
      }
    },
    "Add Repository": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リポジトリを追加"
          }
        }
      }
    },
    "Add Repository…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リポジトリを追加…"
          }
        }
      }
    },
    "Add Session": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションを追加"
          }
        }
      }
    },
    "Add a worktree to this repository": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このリポジトリに worktree を追加"
          }
        }
      }
    },
    "Add…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "追加…"
          }
        }
      }
    },
    "After a successful merge, the worktree and local branch will be deleted.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マージ成功後、worktree とローカルブランチを削除します。"
          }
        }
      }
    },
    "Base Branch": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ベースブランチ"
          }
        }
      }
    },
    "Branch Name": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブランチ名"
          }
        }
      }
    },
    "Branch name: %@": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブランチ名: %@"
          }
