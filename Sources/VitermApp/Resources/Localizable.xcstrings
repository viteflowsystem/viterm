      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペインを閉じる"
          }
        }
      }
    },
    "Command (leave empty to disable)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コマンド(空で無効)"
          }
        }
      }
    },
    "Command Palette": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コマンドパレット"
          }
        }
      }
    },
    "Command Palette…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コマンドパレット…"
          }
        }
      }
    },
    "Copy Claude session data (~/.claude/projects)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Claude セッションデータをコピー(~/.claude/projects)"
          }
        }
      }
    },
    "Copy Claude session data when creating a worktree": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "worktree 作成時に Claude セッションデータをコピー"
