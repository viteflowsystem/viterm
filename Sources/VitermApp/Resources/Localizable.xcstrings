        }
      }
    },
    "Create and Launch": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "作成して起動"
          }
        }
      }
    },
    "Default Preset:": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "既定プリセット:"
          }
