      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新規 worktree — %@"
          }
        }
      }
    },
    "New Worktree…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新規 worktree…"
          }
        }
      }
    },
